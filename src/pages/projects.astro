---
import Base from '../layouts/Base.astro';

const projects = [
  {
    name: 'FRAN',
    description: 'Brutalist life management PWA. Tasks, meals, fitness, money, career, hobbies, weekend planning. Voice commands via Claude AI. Household sharing.',
    tags: ['React 19', 'Vite', 'Supabase', 'Claude API', 'Capacitor'],
    url: 'https://hive-seven-sable.vercel.app',
    github: 'https://github.com/tperumal/fran',
  },
  {
    name: 'Neon Puck',
    description: '2-player air hockey with online multiplayer. Server-authoritative physics at 60 Hz with room-based matchmaking. Supports local 2-player (multi-touch) and online play.',
    tags: ['Canvas', 'Socket.io', 'Node.js', 'Web Audio API'],
    url: 'https://neon-puck.onrender.com',
    github: 'https://github.com/tperumal/neon-puck',
  },
  {
    name: 'Signal & Stories',
    description: 'Economic indicators dashboard tracking Housing, Labor, Inflation, GDP & Growth, and Consumer data from FRED. AI-generated market analysis using Claude. Each card loads independently with its own error state.',
    tags: ['Next.js', 'Claude API', 'Chart.js', 'FRED API'],
    url: 'https://signalandstories.dev',
    github: 'https://github.com/tperumal/signal-and-stories-dashboard',
  },
  {
    name: 'WaterSePush',
    description: 'Aggregates scattered water outage data from South African municipalities into one dashboard. Uses AI to extract structured data from notice images and PDFs published by municipal water utilities.',
    tags: ['Next.js', 'Supabase', 'Claude Vision', 'n8n'],
    url: 'https://watersepush.vercel.app',
    github: 'https://github.com/tperumal/watersepush',
  },
];

const comingSoon = [
  {
    name: 'Gaysingh Road',
    description: 'A project on South African Indians.',
  },
  {
    name: 'Ikhaya Club',
    description: 'An app for family spread apart.',
  },
];
---

<Base title="Projects" description="Things I've built.">
  <section class="hero">
    <h1 class="page-title">PROJECTS</h1>
    <p class="page-desc">Things I've built.</p>
  </section>

  <section class="projects-section">
    {projects.map((project) => (
      <div class="project-card">
        <h2 class="project-name">{project.name}</h2>
        <p class="project-desc">{project.description}</p>
        <div class="project-tags">
          {project.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
        <div class="project-links">
          <a href={project.url} target="_blank" rel="noopener" class="project-link">VIEW LIVE</a>
          <a href={project.github} target="_blank" rel="noopener" class="project-link">GITHUB</a>
        </div>
      </div>
    ))}
  </section>

  <section class="coming-section">
    <span class="section-label">COMING SOON</span>
    {comingSoon.map((project) => (
      <div class="project-card project-card--muted">
        <h2 class="project-name">{project.name}</h2>
        <p class="project-desc">{project.description}</p>
      </div>
    ))}
  </section>
</Base>

<style>
  .hero {
    padding-bottom: 40px;
  }

  .page-title {
    font-family: var(--font-body);
    font-size: var(--text-huge);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  .page-desc {
    font-size: var(--text-body);
    color: var(--fg-50);
  }

  .projects-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    padding-top: 40px;
    border-top: 2px solid var(--fg);
  }

  .coming-section {
    padding-top: 40px;
    margin-top: 40px;
    border-top: 2px solid var(--fg);
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .project-card {
    border: 2px solid var(--fg);
    padding: 20px;
  }

  .project-card--muted {
    opacity: 0.35;
  }

  .project-name {
    font-family: var(--font-body);
    font-weight: 900;
    font-size: var(--text-large);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .project-desc {
    font-size: var(--text-small);
    color: var(--fg-80);
    line-height: 1.6;
    margin-bottom: 14px;
  }

  .project-tags {
    margin-bottom: 16px;
  }

  .project-links {
    display: flex;
    gap: 16px;
  }

  .project-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    border-bottom: 2px solid var(--fg);
    padding-bottom: 2px;
    transition: background 0.1s, color 0.1s;
  }

  .project-link:hover {
    background: var(--fg);
    color: var(--bg);
    padding: 2px 4px;
    margin: -2px -4px;
    margin-bottom: 0;
  }
</style>
