---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Todd Perumal',
  description = 'Builder. San Francisco.',
} = Astro.props;

const pageTitle = title === 'Todd Perumal' ? title : `${title} — Todd Perumal`;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'HOME' },
  { href: '/projects', label: 'PROJECTS' },
  { href: 'https://www.linkedin.com/in/toddperumal/', label: 'LINKEDIN', external: true },
  { href: 'https://github.com/tperumal', label: 'GITHUB', external: true },
  { href: 'https://toddperumal.substack.com', label: 'SUBSTACK', external: true },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={description} />

  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" href="/favicon.png" />

  <ViewTransitions />
</head>
<body>

  <header class="site-header">
    <a href="/" class="site-name">TODD PERUMAL</a>
    <nav class="site-nav-desktop">
      {navLinks.map(({ href, label, external }) => (
        <a
          href={href}
          class:list={['nav-link', { active: !external && (currentPath === href || (href !== '/' && currentPath.startsWith(href))) }]}
          {...(external ? { target: '_blank', rel: 'noopener' } : {})}
        >
          {label}
        </a>
      ))}
    </nav>
    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
  </header>

  <nav class="site-nav-mobile">
    {navLinks.map(({ href, label, external }) => (
      <a
        href={href}
        class:list={['nav-link', { active: !external && (currentPath === href || (href !== '/' && currentPath.startsWith(href))) }]}
        {...(external ? { target: '_blank', rel: 'noopener' } : {})}
      >
        {label}
      </a>
    ))}
  </nav>

  <main class="site-main">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-links">
      <a href="https://www.linkedin.com/in/toddperumal/" target="_blank" rel="noopener" class="footer-link">LINKEDIN</a>
      <a href="https://github.com/tperumal" target="_blank" rel="noopener" class="footer-link">GITHUB</a>
      <a href="https://toddperumal.substack.com" target="_blank" rel="noopener" class="footer-link">SUBSTACK</a>
    </div>
    <p class="footer-copy">&copy; 2026 TODD PERUMAL</p>
  </footer>

  <script>
    function initNav() {
      const toggle = document.querySelector('.nav-toggle');
      const nav = document.querySelector('.site-nav-mobile');
      if (!toggle || !nav) return;

      toggle.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        nav.classList.toggle('open');
        toggle.classList.toggle('active');
      });

      nav.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          toggle.setAttribute('aria-expanded', 'false');
          toggle.classList.remove('active');
          nav.classList.remove('open');
        });
      });
    }

    initNav();
    document.addEventListener('astro:after-swap', initNav);
  </script>
</body>
</html>

<style>
  /* ===== Header ===== */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 var(--page-gutter);
    height: 60px;
    border-bottom: 2px solid var(--fg);
    background: var(--bg);
    z-index: 100;
  }

  .site-name {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  /* ===== Desktop Nav ===== */
  .site-nav-desktop {
    display: flex;
    gap: 24px;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--fg-50);
    padding: 4px 0;
    border-bottom: 2px solid transparent;
    transition: color 0.1s, border-color 0.1s;
  }

  .nav-link:hover {
    color: var(--fg);
    border-bottom-color: var(--fg);
  }

  .nav-link.active {
    color: var(--fg);
    border-bottom-color: var(--fg);
  }

  /* ===== Mobile Toggle ===== */
  .nav-toggle {
    display: none;
    background: none;
    border: 2px solid var(--fg);
    cursor: pointer;
    padding: 8px;
    flex-direction: column;
    gap: 5px;
    width: 36px;
    height: 36px;
    justify-content: center;
    align-items: center;
  }

  .nav-toggle-bar {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--fg);
    transition: transform 0.15s ease;
  }

  .nav-toggle.active .nav-toggle-bar:first-child {
    transform: translateY(3.5px) rotate(45deg);
  }

  .nav-toggle.active .nav-toggle-bar:last-child {
    transform: translateY(-3.5px) rotate(-45deg);
  }

  /* ===== Mobile Nav ===== */
  .site-nav-mobile {
    display: none;
    position: fixed;
    top: 60px;
    left: 0;
    right: 0;
    background: var(--bg);
    border-bottom: 2px solid var(--fg);
    padding: 20px var(--page-gutter);
    flex-direction: column;
    gap: 12px;
    z-index: 99;
    transform: translateY(-100%);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .site-nav-mobile.open {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  /* ===== Main ===== */
  .site-main {
    padding: 80px var(--page-gutter) 60px;
    max-width: 900px;
    margin: 0 auto;
  }

  /* ===== Footer ===== */
  .site-footer {
    max-width: 900px;
    margin: 0 auto;
    padding: 40px var(--page-gutter);
    border-top: 2px solid var(--fg);
  }

  .footer-links {
    display: flex;
    gap: 20px;
    margin-bottom: 16px;
  }

  .footer-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-50);
    letter-spacing: 0.05em;
    border-bottom: 2px solid transparent;
    transition: color 0.1s, border-color 0.1s;
  }

  .footer-link:hover {
    color: var(--fg);
    border-bottom-color: var(--fg);
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-33);
    letter-spacing: 0.05em;
  }

  /* ===== Mobile ===== */
  @media (max-width: 768px) {
    .site-header {
      padding: 0 20px;
    }

    .site-nav-desktop {
      display: none;
    }

    .nav-toggle {
      display: flex;
    }

    .site-nav-mobile {
      display: flex;
    }

    .site-main {
      padding: 80px 20px 40px;
    }

    .site-footer {
      padding: 30px 20px;
    }
  }
</style>
